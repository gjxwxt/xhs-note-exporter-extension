{
  "manifest_version": 3,
  "name": "XHS Note Capture",
  "version": "0.3.0",
  "description": "采集小红书帖子详情页，支持手动采集、自动采集、封面图导出和 Excel 汇总。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://*.xhscdn.com/*",
    "http://*.xhscdn.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html",
    "default_title": "采集小红书帖子"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/user/profile/*",
        "https://www.xiaohongshu.com/explore/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
